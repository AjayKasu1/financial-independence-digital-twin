{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "financial-independence-digital-twin",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,
  "observability": { "enabled": true },
  "assets": {
    "directory": "../../apps/web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "APP_ENV": "demo",
    "OPENROUTER_MODEL": "openrouter/free",
    "APP_PUBLIC_URL": "https://financial-independence-digital-twin.ajaykasu7.workers.dev",
    "SEC_USER_AGENT": "FiduciaryOS research demo contact@example.com"
  },
  "d1_databases": [
    {
      "binding": "FIDT_DB",
      "database_name": "fidt-demo",
      "database_id": "61b9bdc1-e7d7-48b2-ac51-829d27f433c1",
      "migrations_dir": "migrations"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "2774fe30ef6d445cace4e857d2f02794"
    }
  ]
}
