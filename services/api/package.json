{
  "name": "@fidt/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=/tmp/fidt-wrangler.log wrangler dev",
    "build": "WRANGLER_LOG_PATH=/tmp/fidt-wrangler.log wrangler deploy --dry-run --outdir dist",
    "deploy": "WRANGLER_LOG_PATH=/tmp/fidt-wrangler.log wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "WRANGLER_LOG_PATH=/tmp/fidt-wrangler.log wrangler d1 migrations apply FIDT_DB --local",
    "db:seed:local": "WRANGLER_LOG_PATH=/tmp/fidt-wrangler.log wrangler d1 execute FIDT_DB --local --file=./seed.sql"
  },
  "dependencies": {
    "@fidt/ai-orchestrator": "*",
    "@fidt/contracts": "*",
    "@fidt/domain": "*",
    "@fidt/policy-engine": "*",
    "fast-xml-parser": "5.10.1",
    "hono": "4.12.31",
    "jose": "6.2.4",
    "zod": "4.4.3"
  }
}
