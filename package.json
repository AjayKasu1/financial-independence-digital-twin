{
  "name": "financial-independence-digital-twin",
  "version": "0.1.0",
  "private": true,
  "description": "A fiduciary-grade decision intelligence platform for financial advisors.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace @fidt/web",
    "dev:api": "npm run dev --workspace @fidt/api",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm run build --workspace @fidt/web",
    "build:api": "npm run build --workspace @fidt/api",
    "deploy": "npm run build:web && npm run deploy --workspace @fidt/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "db:migrate:local": "npm run db:migrate:local --workspace @fidt/api",
    "db:seed:local": "npm run db:seed:local --workspace @fidt/api",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "decimal.js": "10.6.0",
    "fast-xml-parser": "5.10.1",
    "hono": "4.12.31",
    "jose": "6.2.4",
    "lucide-react": "1.25.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260722.1",
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "9.2.4",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "fast-check": "4.9.0",
    "prettier": "3.9.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.113.0"
  }
}
